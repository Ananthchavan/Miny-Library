<% layout("/layouts/boilerplate.ejs") %>
<div class="cart_page">
    <h2 class="cart_heading">My Cart</h2>

    <% if (!cart || cart.books.length === 0) { %>
        <p>Your cart is empty. <a href="/books">Browse books</a></p>
    <% } else { 
        let totalItems = 0;
        let totalPrice = 0;
    %>
        <div class="cart_wrapper">
        <% for (let item of cart.books) { 
            totalItems += item.quantity;
            totalPrice += item.book.price * item.quantity;
        %>
            <div class="cart_item">
                <a href="/books/<%= item.book._id %>" style="display:contents">
                    <div class="cart_cover">
                        <img class="cart_img" src="<%= item.book.image?.url %>" alt="<%= item.book.title %>">
                    </div>
                    <div class="cart_info">
                        <p class="cart_title"><%= item.book.title %></p>
                        <p class="cart_author"><%= item.book.author %></p>
                        <p class="cart_price">₹<%= item.book.price %></p>
                    </div>
                </a>

                <div class="cart_actions">
                    <form action="/cart/<%= item.book._id %>?_method=PATCH" method="POST">
                        <label>Qty:</label>
                        <input type="number" name="quantity" value="<%= item.quantity %>" min="1" class="cart_qty_input" onchange="this.form.submit()">
                    </form>

                    <p class="cart_item_total">₹<%= item.book.price * item.quantity %></p>

                    <form action="/cart/<%= item.book._id %>?_method=DELETE" method="POST">
                        <button type="submit" class="cart_remove_btn">Remove</button>
                    </form>
                </div>
            </div>
        <% } %>
        </div>

        <div class="cart_summary">
            <div>
                <div class="cart_total_label">Total (<%= totalItems %> items)</div>
                <div class="cart_total_amount">₹<%= totalPrice %></div>
            </div>
            <button class="cart_checkout_btn">Checkout</button>
        </div>
    <% } %>
</div>
