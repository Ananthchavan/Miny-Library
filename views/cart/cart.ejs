<% layout("/layouts/boilerplate.ejs") %>
    <div class="cart_page">
        <h2 class="cart_heading">My Cart</h2>

        <% if (!cart || cart.books.length===0) { %>
            <p>Your cart is empty. <a href="/books">Browse books</a></p>
            <% } else { let totalItems=0; let totalPrice=0; %>
                <div class="cart_wrapper">
                    <% for (let item of cart.books) { totalItems +=item.quantity; totalPrice +=item.book.price *
                        item.quantity; %>
                        <div class="cart_item">
                            <a href="/books/<%= item.book._id %>" style="display:contents">
                                <div class="cart_cover">
                                    <img class="cart_img" src="<%= item.book.image?.url %>"
                                        alt="<%= item.book.title %>">
                                </div>
                                <div class="cart_info">
                                    <p class="cart_title">
                                        <%= item.book.title %>
                                    </p>
                                    <p class="cart_author">
                                        <%= item.book.author %>
                                    </p>
                                    <p class="cart_price">₹<%= item.book.price %>
                                    </p>
                                </div>
                            </a>

                            <div class="cart_actions">
                                <form action="/cart/<%= item.book._id %>?_method=PATCH" method="POST">
                                    <label>Qty:</label>
                                    <input type="number" name="quantity" value="<%= item.quantity %>" min="1"
                                        class="cart_qty_input" onchange="this.form.submit()">
                                </form>

                                <p class="cart_item_total">₹<%= item.book.price * item.quantity %>
                                </p>

                                <form action="/cart/<%= item.book._id %>?_method=DELETE" method="POST">
                                    <button type="submit" class="cart_remove_btn">Remove</button>
                                </form>
                            </div>
                        </div>
                        <% } %>
                </div>

                <div class="cart_summary">
                    <div>
                        <div class="cart_total_label">Total (<%= totalItems %> items)</div>
                        <div class="cart_total_amount">₹<%= totalPrice %>
                        </div>
                    </div>
                    <button id="checkout-btn" class="cart_checkout_btn" onclick="handleCheckout()">Checkout</button>
                </div>
                <% } %>
    </div>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
        async function handleCheckout() {
            const btn = document.getElementById("checkout-btn");
            btn.disabled = true;
            btn.textContent = "Processing...";

            try {
                const res = await fetch("/checkout/create-order", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                });

                if (!res.ok) {
                    const err = await res.json();
                    throw new Error(err.error || "Failed to create order");
                }

                const { order, key } = await res.json();

                // 2. Open Razorpay checkout modal
                const options = {
                    key: key,
                    amount: order.amount,
                    currency: order.currency,
                    name: "Miny Library",
                    description: "Book Purchase",
                    order_id: order.id,
                    handler: async function (response) {
                        try {
                            const verifyRes = await fetch("/checkout/verify-payment", {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify({
                                    razorpay_order_id: response.razorpay_order_id,
                                    razorpay_payment_id: response.razorpay_payment_id,
                                    razorpay_signature: response.razorpay_signature,
                                }),
                            });

                            const data = await verifyRes.json();

                            if (data.success) {
                                window.location.href = data.redirect;
                            } else {
                                alert("Payment verification failed. Please contact support.");
                                btn.disabled = false;
                                btn.textContent = "Checkout";
                            }
                        } catch (err) {
                            alert("Verification error: " + err.message);
                            btn.disabled = false;
                            btn.textContent = "Checkout";
                        }
                    },
                    modal: {
                        ondismiss: function () {
                            btn.disabled = false;
                            btn.textContent = "Checkout";
                        },
                    },
                    theme: {
                        color: "#6c3baa",
                    },
                };

                const rzp = new Razorpay(options);
                rzp.on("payment.failed", function (response) {
                    alert("Payment failed: " + response.error.description);
                    btn.disabled = false;
                    btn.textContent = "Checkout";
                });
                rzp.open();
            } catch (err) {
                alert("Error: " + err.message);
                btn.disabled = false;
                btn.textContent = "Checkout";
            }
        }
    </script>