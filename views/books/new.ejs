<% layout("/layouts/boilerplate.ejs") %>

<div class="new_cont">
    <h1>Add New Book</h1>
        <form method="POST" action="/books" enctype="multipart/form-data">
            <div class="new_ele">
            <div>
                <label for="title">Title</label>
                <input type="text" name="Book[title]" />
            </div>

            <div>
                <label for="image" >Image</label>
                <input type="file" name="Book[image]"/>
            </div>

            <div>
                <label for="author" >Author</label>
                <input type="text" name="Book[author]"/>
            </div>

            <div>
                <label for="desc" >Description</label>
                <input type="text" name="Book[description]"/>
            </div>

            <div>
                <label for="year" >Year</label>
                <input type="number" name="Book[year]"/>
            </div>

            <div>
                <label for="price" >Price</label>
                <input type="number" name="Book[price]"/>
            </div>

            <div>
                <label for="stock" >Stock</label>
                <input type="number" name="Book[stock]"/>
            </div>
        </div>
            <button class="new_btn" type="submit">Create Book</button>
        </form>
</div>