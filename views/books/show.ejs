<% layout("/layouts/boilerplate.ejs") %>

<div class="container1">
            <div class="card">
                <p class="head"><%= book1.title %></p>
                <img class="img_book" src="<%= book1.image %>" alt="<%= book1.title %>">
                <p><%= book1.author %></p>
                <p><%= book1.price %></p>
                <p><%= book1.description %></p>
                <p><%= book1.year %></p>
                <p><%= book1.price %></p>

                <form action="/books/<%=book1._id%>/edit" method="GET">
                    <button>Edit</button>
                </form>

                <form method="POST" action="/books/<%=book1._id%>?_method=DELETE">
                    <button>Delete</button>
                </form>
                
            </div>
</div>