            <input name="search" placeholder="  Enter Name/Author" class="search_bar"/>
            <button class="search_btn">Search</button>
        </form >
        <a class="nav-all icon3" href="/logout">Logout</a>
        <a class="nav-all icon4" href="/profile"> <i class="fa-regular fa-user"></i> Profile</a>
    <% } %>
    
</div>