<div class="library-nav">
    <a class="nav-home" href="/">Home</a>
    <a class="nav-all" href="/books">All Books</a>
    <% if (currentUser && currentUser.role === "admin") { %>
        <a class="nav-new" href="/books/new">Add new Book</a>
    <% } %>
    <% if(!currentUser){ %>
        <a class="nav-all " href="/admin/signup">Admin SignUp</a>
        <form action="/search" method="POST">
            <input name="search" placeholder="  Enter Name/Author" class="search_bar"/>
            <button class="search_btn">Search</button>
        </form >
        <a class="nav-all icon1" href="/signup">SignUp</a>
        <a class="nav-all icon2" href="/login">Login</a>
    <% } %>
    <% if(currentUser) { %>
        <% if (currentUser.role === "user") { %>
            <a class="nav-new" href="/cart"><i class="fa-solid fa-basket-shopping"></i> Your Cart</a>
            <a class="nav-new" href="/wishlist"><i class="fa-regular fa-heart"></i> WishList</a>
            <a class="nav-new" href="/borrow"> Borrowed Books</a>
        <% } %>
