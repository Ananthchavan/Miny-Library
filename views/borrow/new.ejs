<% layout("/layouts/boilerplate.ejs") %>

<h1 class="borrow_heading">Borrow: <%= book.title %></h1>

<div class="borrow_container">

    <!-- LEFT -->
    <div class="book-summary">
        <img src="<%= book.image.url %>" alt="<%= book.title %>" class="borrow_img"/>

        <div class="book_details">
            <p><strong>Author:</strong> <%= book.author %></p>
            <p><strong>Price:</strong> ₹<%= book.price %></p>
        </div>
    </div>

    <!-- RIGHT -->
    <form action="/borrow/<%= book._id %>" method="POST" class="borrow_form">

        <h2>Select Borrow Duration</h2>

        <div class="day-options">
            <% for (let opt of options) { %>
                <label class="day-btn">
                    <input
                        type="radio"
                        name="days"
                        value="<%= opt.days %>"
                        onchange="updateBill(<%= opt.days %>, <%= opt.charge %>)"
                        <%= opt.days === 7 ? "checked" : "" %>
                    />
                    <span><%= opt.days %> Days</span>
                </label>
            <% } %>
        </div>

        <!-- BILL SUMMARY -->
        <div class="bill-summary">
            <h2>Bill Summary</h2>

            <table>
                <tr>
                    <td>Book</td>
                    <td><%= book.title %></td>
                </tr>

                <tr>
                    <td>Duration</td>
                    <td id="bill-days">7 days</td>
                </tr>

                <tr>
                    <td>Daily Rate</td>
                    <td><%= ((2/100) * book.price).toFixed(2) %> / day</td>
                </tr>

                <tr>
                    <td>Due Date</td>
                    <td id="bill-due"></td>
                </tr>

                <tr>
                    <td><strong>Total Charge</strong></td>
                    <td><strong id="bill-total"><%= options[0].charge %></strong></td>
                </tr>
            </table>
        </div>

        <div class="borrow_btns">
            <button type="submit" class="confirm_btn">Confirm Borrow</button>
            <a href="/books/<%= book._id %>" class="cancel_btn">Cancel</a>
        </div>

    </form>
</div>

<script>
    function updateBill(days,charge) {
        document.getElementById("bill-days").textContent = days + " days";
        document.getElementById("bill-total").textContent = charge.toFixed(2);

        const duedate = new Date();
        duedate.setDate(duedate.getDate() + days);

        document.getElementById("bill-due").textContent =
            duedate.toDateString();
    }

    updateBill(7, <%= options[0].charge %>);
</script>

<style>

/* PAGE */
.borrow_heading{
    text-align:center;
    color:#4B2E2B;
    margin-top:30px;
}

.borrow_container{
    display:flex;
    justify-content:center;
    align-items:flex-start;
    gap:40px;
    margin:40px auto;
    max-width:1100px;
    padding:20px;
}

/* LEFT CARD */
.book-summary{
    background:#E8DFC9;
    padding:25px;
    border-radius:14px;
    width:320px;
    box-shadow:0 6px 15px rgba(0,0,0,0.1);
    text-align:center;
}

.borrow_img{
    width:220px;
    height:300px;
    object-fit:cover;
    border-radius:10px;
}

.book_details{
    margin-top:20px;
}

.book_details p{
    color:#4B2E2B;
    margin:10px 0;
    font-size:16px;
}

/* RIGHT FORM */
.borrow_form{
    background:#E8DFC9;
    padding:30px;
    border-radius:14px;
    width:500px;
    box-shadow:0 6px 15px rgba(0,0,0,0.1);
}

.borrow_form h2{
    color:#4B2E2B;
    margin-bottom:20px;
}

/* DAY OPTIONS */
.day-options{
    display:flex;
    gap:15px;
    margin-bottom:25px;
    flex-wrap:wrap;
}

.day-btn input{
    display:none;
}

.day-btn span{
    display:block;
    padding:12px 18px;
    border:2px solid #8B6F47;
    border-radius:10px;
    cursor:pointer;
    font-weight:bold;
    background:#F5EFE6;
    color:#4B2E2B;
    transition:0.2s;
}

.day-btn span:hover{
    background:#e9dcc9;
}

.day-btn input:checked + span{
    background:#4B2E2B;
    color:#F5EFE6;
    border-color:#4B2E2B;
}

/* BILL */
.bill-summary{
    background:#F5EFE6;
    padding:20px;
    border-radius:10px;
}

.bill-summary table{
    width:100%;
    border-collapse:collapse;
}

.bill-summary td{
    padding:12px 8px;
    border-bottom:1px solid #ddd;
    color:#4B2E2B;
}

/* BUTTONS */
.borrow_btns{
    display:flex;
    gap:15px;
    margin-top:25px;
}

.confirm_btn{
    background:#4B2E2B;
    color:#F5EFE6;
    border:none;
    padding:12px 18px;
    border-radius:8px;
    cursor:pointer;
    font-weight:bold;
    transition:0.2s;
}

.confirm_btn:hover{
    background:#3a2220;
}

.cancel_btn{
    background:#7A3E3E;
    color:#F5EFE6;
    padding:12px 18px;
    border-radius:8px;
    text-decoration:none;
    font-weight:bold;
    transition:0.2s;
}

.cancel_btn:hover{
    background:#5f2f2f;
}

</style>