<% layout("/layouts/boilerplate.ejs") %>
<h2 class="wish_heading">My WishList</h2>

<% if(!wishList || wishList.books.length == 0) { %>
    <p class="wish_heading">Your wishlist is empty. <a href="/books">Browse books</a></p>
<% } else { %>
    <div class="wishlist_wrapper">
    <% for(let book of wishList.books){ %>
        <div class="wishlist_item">
            <a href="/books/<%= book._id %>" style="display:contents">
                <div class="wishlist_cover">
                    <img class="wishlist_img" src="<%= book.image?.url %>" alt="<%= book.title %>">
                </div>
                <div class="wishlist_info">
                    <p class="wishlist_title"><%= book.title %></p>
                    <p class="wishlist_author"><%= book.author %></p>
                    <p class="wishlist_price"><%= book.price %></p>
                </div>
            </a>
            <form class="wishlist_form" action="/wishlist/<%= book._id %>?_method=DELETE" method="POST">
                <button type="submit" class="wishlist_remove_btn">Remove</button>
            </form>
        </div>
    <% } %>
    </div>
<% } %>